#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
QSYS_DIR="$ROOT_DIR/hw/de10/qsys"
QSYS_OUT_DIR="$QSYS_DIR/generated"
SOC_QSYS_SCRIPT="$QSYS_DIR/create_de10_soc.tcl"
SOC_QSYS_FILE="$QSYS_DIR/de10_soc.qsys"
SOC_QSYS_OUT_DIR="$QSYS_OUT_DIR"
PLL_QSYS_SCRIPT="$QSYS_DIR/create_de10_core_pll.tcl"
PLL_QSYS_FILE="$QSYS_DIR/de10_core_pll.qsys"
PLL_QSYS_OUT_DIR="$QSYS_OUT_DIR/pll"
PLL_OUTPUT_CLOCK_MHZ="${DE10_CORE_CLOCK_MHZ:-50.0}"
FABRIC_CLOCK_HZ="$(python3 - <<'PY'
import os
mhz = float(os.environ.get('DE10_CORE_CLOCK_MHZ', '50.0'))
print(int(round(mhz * 1000000.0)))
PY
)"

python3 - <<'PY'
import os, sys
value = os.environ.get('DE10_CORE_CLOCK_MHZ', '50.0')
try:
    mhz = float(value)
except ValueError:
    print(f"[de10] invalid DE10_CORE_CLOCK_MHZ: {value!r}", file=sys.stderr)
    raise SystemExit(2)
if mhz <= 0.0:
    print(f"[de10] DE10_CORE_CLOCK_MHZ must be positive, got {mhz}", file=sys.stderr)
    raise SystemExit(2)
PY

if ! command -v qsys-script >/dev/null 2>&1; then
  echo "qsys-script not found in PATH" >&2
  echo "Install/enter nix shell with quartus-prime-lite first." >&2
  exit 1
fi

if ! command -v qsys-generate >/dev/null 2>&1; then
  echo "qsys-generate not found in PATH" >&2
  echo "Install/enter nix shell with quartus-prime-lite first." >&2
  exit 1
fi

for required_script in "$SOC_QSYS_SCRIPT" "$PLL_QSYS_SCRIPT"; do
  if [[ ! -f "$required_script" ]]; then
    echo "Missing expected Qsys script: $required_script" >&2
    exit 1
  fi
done

mkdir -p "$QSYS_OUT_DIR"

echo "[de10] DE10 core fabric clock: ${PLL_OUTPUT_CLOCK_MHZ} MHz (${FABRIC_CLOCK_HZ} Hz)"

echo "[de10] Creating Platform Designer system"
(cd "$ROOT_DIR" && qsys-script --script="$SOC_QSYS_SCRIPT" --cmd="set fabric_clock_hz $FABRIC_CLOCK_HZ")

if [[ ! -f "$SOC_QSYS_FILE" ]]; then
  echo "Failed to create Qsys file: $SOC_QSYS_FILE" >&2
  exit 1
fi

python3 - "$SOC_QSYS_FILE" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
text = path.read_text()
fixed = text.replace("<parameter name=\"F2SDRAM_Type\">Avalon-MM,Bidirectional</parameter>",
                     "<parameter name=\"F2SDRAM_Type\">Avalon-MM Bidirectional</parameter>")
if fixed != text:
    path.write_text(fixed)
PY

echo "[de10] Generating Platform Designer synthesis outputs"
qsys-generate "$SOC_QSYS_FILE" --synthesis=VERILOG --output-directory="$SOC_QSYS_OUT_DIR"

if [[ ! -f "$SOC_QSYS_OUT_DIR/synthesis/de10_soc.qip" ]]; then
  echo "Missing expected generated QIP: $SOC_QSYS_OUT_DIR/synthesis/de10_soc.qip" >&2
  exit 1
fi

mkdir -p "$PLL_QSYS_OUT_DIR"

echo "[de10] Creating shared-clock PLL system"
(cd "$ROOT_DIR" && qsys-script --script="$PLL_QSYS_SCRIPT" --cmd="set output_clock_mhz $PLL_OUTPUT_CLOCK_MHZ")

if [[ ! -f "$PLL_QSYS_FILE" ]]; then
  echo "Failed to create Qsys file: $PLL_QSYS_FILE" >&2
  exit 1
fi

echo "[de10] Generating shared-clock PLL synthesis outputs"
qsys-generate "$PLL_QSYS_FILE" --synthesis=VERILOG --output-directory="$PLL_QSYS_OUT_DIR"

if [[ ! -f "$PLL_QSYS_OUT_DIR/synthesis/de10_core_pll.qip" ]]; then
  echo "Missing expected generated QIP: $PLL_QSYS_OUT_DIR/synthesis/de10_core_pll.qip" >&2
  exit 1
fi
