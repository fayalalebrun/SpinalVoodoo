#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"

HOST="${DE10_HOST:-debian-fpga.local}"
USER_NAME="${DE10_USER:-fpga}"
RBF_FILE="${DE10_RBF:-$ROOT_DIR/output/de10/bitstream/SpinalVoodoo_de10.rbf}"
STATE_MARKER="${DE10_STATE_FILE:-/home/fpga/spinalvoodoo/current/.fpga-programmed.sha256}"
REMOTE_DIR="${DE10_TRACE_REMOTE_DIR:-/home/fpga/trace-replay}"
INPUT_PATH="${DE10_TRACE_INPUT:-$ROOT_DIR/traces/tomb}"
OUTPUT_DIR="${DE10_TRACE_OUTPUT_DIR:-$ROOT_DIR/output/de10-board-trace/tomb}"
TRACE_REPLAY_BIN="${DE10_TRACE_REPLAY_BIN:-$ROOT_DIR/output/de10/bin/de10-trace-replay}"
VERIFY_ONLY=0
REPLAY_ARGS=()

usage() {
  cat <<'EOF'
Usage: scripts/run-de10-trace-replay [options]

Options:
  --host <host>         DE10 host
  --user <user>         SSH user (default: fpga)
  --input <path>        Trace directory or trace.bin path (default: traces/tomb)
  --output-dir <path>   Local output dir (default: output/de10-board-trace/tomb)
  --remote-dir <path>   Remote staging dir (default: /home/fpga/trace-replay)
  --verify-programmed   Skip reprogramming; require the programmed marker to match
  --reset-before-playback  Pulse FPGA fabric reset before state load and trace replay
  --skip-fb-state       Do not preload framebuffer bytes from state.bin before replay
  --dump-texture        Dump full texture memory after replay to trace_board_tex.bin
  --preload-trace-textures  Preload all texture writes before replay and skip them in-stream
  --tex-write-delay-us N    Delay after each texture write during replay
  --idle-after-tex-batch    Wait for core idle when leaving a texture-write burst
  -h, --help            Show this help
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      HOST="$2"
      shift 2
      ;;
    --user)
      USER_NAME="$2"
      shift 2
      ;;
    --input)
      INPUT_PATH="$2"
      shift 2
      ;;
    --output-dir)
      OUTPUT_DIR="$2"
      shift 2
      ;;
    --remote-dir)
      REMOTE_DIR="$2"
      shift 2
      ;;
    --verify-programmed)
      VERIFY_ONLY=1
      shift
      ;;
    --reset-before-playback)
      REPLAY_ARGS+=("$1")
      shift
      ;;
    --skip-fb-state)
      REPLAY_ARGS+=("$1")
      shift
      ;;
    --dump-texture)
      REPLAY_ARGS+=("$1")
      shift
      ;;
    --preload-trace-textures)
      REPLAY_ARGS+=("$1")
      shift
      ;;
    --tex-write-delay-us)
      REPLAY_ARGS+=("$1" "$2")
      shift 2
      ;;
    --idle-after-tex-batch)
      REPLAY_ARGS+=("$1")
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [[ -d "$INPUT_PATH" ]]; then
  TRACE_FILE="$INPUT_PATH/trace.bin"
  STATE_FILE="$INPUT_PATH/state.bin"
else
  TRACE_FILE="$INPUT_PATH"
  STATE_FILE="$(dirname "$INPUT_PATH")/state.bin"
fi

if [[ ! -f "$TRACE_FILE" ]]; then
  echo "Missing trace file: $TRACE_FILE" >&2
  exit 1
fi
if [[ ! -x "$TRACE_REPLAY_BIN" ]]; then
  echo "Missing built trace replay binary: $TRACE_REPLAY_BIN" >&2
  echo "Build it first with: make de10/trace/build" >&2
  exit 1
fi
if [[ ! -f "$STATE_FILE" ]]; then
  STATE_FILE=""
fi

REMOTE_TARGET="${USER_NAME}@${HOST}"
mkdir -p "$OUTPUT_DIR"

if [[ "$VERIFY_ONLY" -eq 0 ]]; then
  "$ROOT_DIR/scripts/program-de10" --host "$HOST" --user "$USER_NAME" --rbf "$RBF_FILE" --state-file "$STATE_MARKER"
else
  local_hash="$(sha256sum "$RBF_FILE" | cut -d ' ' -f 1)"
  remote_hash="$(ssh "$REMOTE_TARGET" "test -f '$STATE_MARKER' && head -n 1 '$STATE_MARKER' | cut -d ' ' -f 1 || true")"
  if [[ "$remote_hash" != "$local_hash" ]]; then
    echo "Remote programmed bitstream marker does not match $RBF_FILE" >&2
    exit 1
  fi
fi

ssh "$REMOTE_TARGET" "mkdir -p '$REMOTE_DIR'"
ssh "$REMOTE_TARGET" "rm -f '$REMOTE_DIR/trace.bin' '$REMOTE_DIR/state.bin' '$REMOTE_DIR/trace_board_fb.raw' '$REMOTE_DIR/trace_board_fb.png' '$REMOTE_DIR/de10-trace-replay'"
scp "$TRACE_REPLAY_BIN" "$REMOTE_TARGET:$REMOTE_DIR/de10-trace-replay"
scp "$TRACE_FILE" "$REMOTE_TARGET:$REMOTE_DIR/trace.bin"
if [[ -n "$STATE_FILE" ]]; then
  scp "$STATE_FILE" "$REMOTE_TARGET:$REMOTE_DIR/state.bin"
fi

LOG_FILE="$OUTPUT_DIR/replay.log"
ssh "$REMOTE_TARGET" "sudo -n '$REMOTE_DIR/de10-trace-replay' '$REMOTE_DIR' ${REPLAY_ARGS[*]} 2>&1" | tee "$LOG_FILE"

RAW_FILE="$OUTPUT_DIR/trace_board_fb.raw"
PNG_FILE="$OUTPUT_DIR/trace_board_fb.png"

scp "$REMOTE_TARGET:$REMOTE_DIR/trace_board_fb.raw" "$RAW_FILE"
if ssh "$REMOTE_TARGET" "test -f '$REMOTE_DIR/trace_board_fb.png'"; then
  scp "$REMOTE_TARGET:$REMOTE_DIR/trace_board_fb.png" "$PNG_FILE"
else
  if [[ -z "$STATE_FILE" ]]; then
    echo "Missing state file for local PNG fallback: $TRACE_FILE" >&2
    exit 1
  fi
  readarray -t FB_META < <(python3 - <<'PY' "$STATE_FILE"
import struct, sys
data = open(sys.argv[1], 'rb').read(64)
fields = struct.unpack('<16I', data)
row_width = fields[9]
h_disp = fields[12]
v_disp = fields[13]
print(row_width)
print(h_disp)
print(v_disp)
PY
)
  ROW_BYTES="${FB_META[0]}"
  WIDTH="${FB_META[1]}"
  HEIGHT="${FB_META[2]}"
  python3 "$ROOT_DIR/scripts/rgb565_to_png.py" "$RAW_FILE" "$PNG_FILE" "$WIDTH" "$HEIGHT" "$ROW_BYTES"
fi

echo "[de10-trace] Screenshot: $PNG_FILE"
echo "[de10-trace] Replay log: $LOG_FILE"
