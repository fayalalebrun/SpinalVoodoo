#!/usr/bin/env python3
"""Convert SRLE framebuffer dump to PNG.

SRLE format (written by tlib.c tlScreenDump):
  4 bytes: signature 0x53524C45 ("SRLE")
  2 bytes: width  (little-endian)
  2 bytes: height (little-endian)
  1 byte:  depth  (bits per pixel, 16 for SST1 RGB565)
  1 byte:  type   (1 = RLE encoded)
  rest:    RLE-encoded pixel data

RLE encoding (depth=16, 2 bytes per pixel):
  Control byte:
    bit 7 set   -> run:     count = (ctrl & 0x7F) + 1, followed by one pixel
    bit 7 clear -> literal: count = (ctrl & 0x7F) + 1, followed by count pixels

Output is a minimal PNG written with only struct and zlib (no Pillow).
"""

import struct
import sys
import zlib


def decode_srle(data):
    sig, width, height, depth, typ = struct.unpack_from('<IHHBB', data)
    if sig != 0x53524C45:
        raise ValueError(f'Bad SRLE signature: 0x{sig:08X}')
    if typ != 1:
        raise ValueError(f'Unsupported SRLE type: {typ}')
    bpp = depth // 8  # bytes per pixel (2 for RGB565)
    total = width * height
    pixels = bytearray(total * bpp)
    pos = 10  # past header
    out = 0
    while out < total:
        ctrl = data[pos]; pos += 1
        count = (ctrl & 0x7F) + 1
        if ctrl & 0x80:
            # run
            px = data[pos:pos + bpp]; pos += bpp
            for _ in range(count):
                pixels[out * bpp:(out + 1) * bpp] = px
                out += 1
        else:
            # literal
            for _ in range(count):
                pixels[out * bpp:(out + 1) * bpp] = data[pos:pos + bpp]
                pos += bpp
                out += 1
    return width, height, depth, pixels


def rgb565_to_rgb888(pixels, width, height):
    """Convert RGB565 pixel buffer to RGB888."""
    rgb = bytearray(width * height * 3)
    for i in range(width * height):
        lo = pixels[i * 2]
        hi = pixels[i * 2 + 1]
        val = lo | (hi << 8)
        r = (val >> 11) & 0x1F
        g = (val >> 5) & 0x3F
        b = val & 0x1F
        # Expand to 8-bit with rounding
        r = (r << 3) | (r >> 2)
        g = (g << 2) | (g >> 4)
        b = (b << 3) | (b >> 2)
        j = i * 3
        rgb[j] = r
        rgb[j + 1] = g
        rgb[j + 2] = b
    return rgb


def write_png(path, width, height, rgb):
    """Write a minimal 8-bit RGB PNG using only struct and zlib."""
    def chunk(ctype, data):
        c = ctype + data
        return struct.pack('>I', len(data)) + c + struct.pack('>I', zlib.crc32(c) & 0xFFFFFFFF)

    # Build raw image data with filter byte (0 = None) per row
    raw = bytearray()
    stride = width * 3
    for y in range(height):
        raw.append(0)  # filter type None
        raw.extend(rgb[y * stride:(y + 1) * stride])

    with open(path, 'wb') as f:
        f.write(b'\x89PNG\r\n\x1a\n')
        # IHDR: width, height, bit_depth=8, color_type=2 (RGB), compression=0, filter=0, interlace=0
        f.write(chunk(b'IHDR', struct.pack('>IIBBBBB', width, height, 8, 2, 0, 0, 0)))
        f.write(chunk(b'IDAT', zlib.compress(bytes(raw))))
        f.write(chunk(b'IEND', b''))


def main():
    if len(sys.argv) != 3:
        print(f'Usage: {sys.argv[0]} input.srle output.png', file=sys.stderr)
        sys.exit(1)

    with open(sys.argv[1], 'rb') as f:
        data = f.read()

    width, height, depth, pixels = decode_srle(data)
    if depth != 16:
        print(f'Unsupported depth: {depth} (expected 16)', file=sys.stderr)
        sys.exit(1)

    rgb = rgb565_to_rgb888(pixels, width, height)
    write_png(sys.argv[2], width, height, rgb)
    print(f'{sys.argv[1]} -> {sys.argv[2]} ({width}x{height})', file=sys.stderr)


if __name__ == '__main__':
    main()
